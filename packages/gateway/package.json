{
  "name": "@simpleclaw/gateway",
  "version": "1.0.0",
  "description": "Simpleclaw agent gateway daemon",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./main": {
      "import": "./dist/main.js"
    }
  },
  "files": [
    "dist",
    "prisma",
    "templates"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "config:schema": "tsx src/config/schema-json.ts",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "simpleclaw",
    "agent",
    "gateway",
    "telegram"
  ],
  "license": "ISC",
  "packageManager": "pnpm@10.12.3",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.44",
    "@ai-sdk/google": "^3.0.29",
    "@ai-sdk/mistral": "^3.0.20",
    "@ai-sdk/openai": "^3.0.29",
    "@ai-sdk/provider": "^3.0.8",
    "@ai-sdk/xai": "^3.0.57",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@openrouter/ai-sdk-provider": "^2.2.3",
    "@prisma/client": "^6.16.3",
    "ai": "^6.0.86",
    "cron": "^4.4.0",
    "grammy": "^1.35.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "prisma": "^6.16.3",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^4.0.18"
  }
}
