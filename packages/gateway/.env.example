# DEPRECATED: Runtime config is JSON-only.
# The bot now reads configuration from ~/.simpleclaw/simpleclaw.json
# (or SIMPLECLAW_CONFIG_PATH override). This file is kept for migration reference.
BOT_TOKEN=
AI_GATEWAY_API_KEY=
AI_MODEL=anthropic/claude-sonnet-4-20250514
DATABASE_URL="file:../data/simpleclaw.db"
WORKSPACE_ROOT=
MAX_MESSAGES_PER_SESSION=120
HISTORY_LIMIT=40
SESSION_REPLY_CHAIN_MODE=default
ENABLE_GENERIC_TOOLS=true
