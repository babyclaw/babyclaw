datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum MessageRole {
  system
  user
  assistant
}

enum ScheduleType {
  one_off
  recurring
}

enum ScheduleStatus {
  active
  canceled
  completed
}

enum ScheduleRunStatus {
  pending
  running
  succeeded
  failed
  skipped_overlap
  skipped_downtime
}

model Chat {
  id              String    @id @default(cuid())
  platform        String
  platformChatId  String
  type            String
  title           String?
  alias           String?
  isMain          Boolean   @default(false)
  linkedAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([platform, platformChatId])
  @@unique([platform, alias])
}

model Session {
  id                      String    @id @default(cuid())
  key                     String    @unique
  chatId                  BigInt
  threadId                BigInt?
  lastActivityAt          DateTime?
  memoriesLastExtractedAt DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  messages                Message[]
}

model Message {
  id        String      @id @default(cuid())
  sessionId String
  session   Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      MessageRole
  content   String
  metadata  String?
  createdAt DateTime    @default(now())

  @@index([sessionId, createdAt])
}

model Schedule {
  id                   String               @id @default(cuid())
  chatId               BigInt
  createdByUserId      BigInt
  threadId             BigInt?
  directMessagesTopicId BigInt?
  title                String?
  taskPrompt           String
  sourceText           String
  type                 ScheduleType
  cronExpression       String?
  runAt                DateTime?
  timezone             String
  status               ScheduleStatus       @default(active)
  nextRunAt            DateTime?
  lastRunAt            DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  targetChatRef        String?
  canceledAt           DateTime?
  runs                 ScheduleRun[]
  links                ChannelMessageLink[]

  @@index([chatId, status, nextRunAt])
}

model ScheduleRun {
  id               String            @id @default(cuid())
  scheduleId       String
  schedule         Schedule          @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  scheduledFor     DateTime
  status           ScheduleRunStatus @default(pending)
  attempt          Int               @default(1)
  sessionKey       String?
  assistantMessageId BigInt?
  error            String?
  startedAt        DateTime?
  finishedAt       DateTime?
  createdAt        DateTime          @default(now())
  links            ChannelMessageLink[]

  @@index([scheduleId, createdAt])
  @@index([status, createdAt])
  @@index([sessionKey])
}

enum HeartbeatOutcome {
  ok
  alerted
  error
  skipped_overlap
  skipped_empty
}

model HeartbeatRun {
  id         String           @id @default(cuid())
  startedAt  DateTime
  finishedAt DateTime?
  outcome    HeartbeatOutcome
  summary    String?
  error      String?
  createdAt  DateTime         @default(now())

  @@index([createdAt])
}

model ChannelMessageLink {
  id                String       @id @default(cuid())
  platform          String
  platformChatId    String
  platformMessageId String
  sessionKey        String
  scheduleId        String?
  schedule          Schedule?    @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  scheduleRunId     String?
  scheduleRun       ScheduleRun? @relation(fields: [scheduleRunId], references: [id], onDelete: SetNull)
  createdAt         DateTime     @default(now())

  @@unique([platform, platformChatId, platformMessageId])
  @@index([sessionKey])
  @@index([scheduleId])
  @@index([scheduleRunId])
}
