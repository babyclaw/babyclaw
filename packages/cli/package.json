{
  "name": "@simpleclaw/cli",
  "version": "1.0.0",
  "description": "The simpleclaw command-line interface",
  "type": "module",
  "bin": {
    "simpleclaw": "./build/cli.js"
  },
  "files": [
    "build"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
