{
  "name": "babyclaw",
  "version": "0.2.0",
  "description": "The babyclaw command-line interface",
  "keywords": [
    "agent",
    "babyclaw",
    "cli",
    "gateway"
  ],
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/babyclaw/babyclaw",
    "directory": "packages/cli"
  },
  "bin": {
    "babyclaw": "./build/cli.js"
  },
  "files": [
    "build"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@babyclaw/gateway": "workspace:*",
    "@gud/cli": "1.0.0-beta.7",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "oxlint": "^1.49.0",
    "typescript": "^5.9.2",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
