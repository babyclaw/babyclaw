{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": false,
    "sourceMap": false,
    "outDir": "build",
    "rootDir": "source",
    "types": ["node"]
  },
  "include": ["source/**/*.ts"],
  "exclude": ["build", "node_modules"]
}
